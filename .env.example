APP_NAME="Sheffield Africa"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Pusher / Broadcasting
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=
PUSHER_PORT=443
PUSHER_SCHEME=https

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"

# Social Login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=
GOOGLE_MAPS_API_KEY=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URL=

# Pesawise Payment Gateway
PESAWISE_API_URL=https://api.pesawise.xyz/api
PESAWISE_API_KEY=
PESAWISE_API_SECRET=
PESAWISE_BALANCE_ID_KES=
PESAWISE_BALANCE_ID_USD=
# For local development with ngrok/expose (leave empty for production)
# Example: PESAWISE_CALLBACK_BASE_URL=https://abc123.ngrok.io
PESAWISE_CALLBACK_BASE_URL=

# M-Pesa
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=

# PayPal
PAYPAL_ENV=sandbox
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_SECRET=
PAYPAL_LIVE_CLIENT_ID=
PAYPAL_LIVE_SECRET=
PAYPAL_WEBHOOK_ID=

# Stripe
CASHIER_CURRENCY=kes
CASHIER_LOGGER=stack
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# SAP Middleware
SAP_BASE_URL=
SAP_WEBHOOK_SECRET=
KRA_BUSINESS_PIN=

# Backup Configuration
BACKUP_FILENAME_PREFIX="sheffield-backup-"
BACKUP_NOTIFICATION_EMAIL="admin@sheffieldafrica.com"
BACKUP_ARCHIVE_PASSWORD=
BACKUP_DRIVE_PATH=
# MySQL dump binary path (Windows)
MYSQLDUMP_PATH="C:\\Program Files\\MySQL\\MySQL Server 8.0\\bin\\mysqldump.exe"
# For cloud storage backups (optional)
# AWS_BACKUP_BUCKET=
# BACKUP_CLOUD_ENABLED=false

# PDF Generation (Spatie Laravel PDF with Browsershot)
# Driver: browsershot, cloudflare, dompdf, gotenberg, weasyprint
LARAVEL_PDF_DRIVER=browsershot

# Browsershot Configuration (for Chromium-based PDF generation)
# Leave these empty to use auto-detection (recommended for most setups)
LARAVEL_PDF_NODE_BINARY=
LARAVEL_PDF_NPM_BINARY=
LARAVEL_PDF_CHROME_PATH=
LARAVEL_PDF_NODE_MODULES_PATH=
LARAVEL_PDF_BIN_PATH=
LARAVEL_PDF_INCLUDE_PATH=
LARAVEL_PDF_TEMP_PATH=
LARAVEL_PDF_WRITE_OPTIONS_TO_FILE=true
LARAVEL_PDF_NO_SANDBOX=false

# Alternative PDF Drivers (if not using Browsershot)
# Cloudflare Browser Rendering
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Gotenberg (Docker-based)
# GOTENBERG_URL=http://localhost:3000
# GOTENBERG_USERNAME=
# GOTENBERG_PASSWORD=

# WeasyPrint
# LARAVEL_PDF_WEASYPRINT_BINARY=weasyprint

# DOMPDF (fallback - lower quality)
# LARAVEL_PDF_DOMPDF_REMOTE_ENABLED=false
# LARAVEL_PDF_DOMPDF_CHROOT=

# Activity Log Configuration
ACTIVITY_LOGGER_ENABLED=true
